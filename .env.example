# ─── Backend (FRAS API) ───────────────────────────────────
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:4321,http://localhost:8000

# Redis: set USE_FAKE_REDIS=False and provide REDIS_URL to use real Redis
USE_FAKE_REDIS=True
REDIS_URL=redis://localhost:6379

# Telegram/Discord webhook alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Minimum 24h volume in USD (prevents low-liquidity analysis)
MIN_24H_VOLUME_USD=10000000

# ─── Frontend (Astro / React) ─────────────────────────────
# URL of the deployed backend API (set during build)
PUBLIC_API_URL=http://localhost:8000
